          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "SigninLogs\r\n| where UserPrincipalName startswith \"{UPN_Prefix}\" or (Identity contains \"{FirstName}\" and Identity contains \"{LastName}\")\r\n| extend UPN_Prefix = split(UserPrincipalName, \"@\").[0]\r\n| extend UPN_Prefix = split(UPN_Prefix, \".\").[-1]\r\n| where UPN_Prefix != \"admin\"\r\n| summarize arg_max(TimeGenerated, *) by UserPrincipalName\r\n| extend State = LocationDetails.state\r\n| extend City = LocationDetails.city\r\n| extend DeviceName = DeviceDetail.displayName\r\n| project TimeGenerated, DisplayName=Identity, UserPrincipalName, UserId, Country=Location, State, City, DeviceName, IPAddress",
