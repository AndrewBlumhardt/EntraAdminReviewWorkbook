          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "SigninLogs\r\n| where UserPrincipalName == \"{UserPrincipalName}\"\r\n| extend State = LocationDetails.state\r\n| extend City = LocationDetails.city\r\n| extend DeviceName = DeviceDetail.displayName\r\n| extend Browser = DeviceDetail.browser\r\n| extend OS = DeviceDetail.operatingSystem\r\n| extend NetworkType = parse_json(NetworkLocationDetails)[1].networkType\r\n| extend Network = parse_json(tostring(parse_json(NetworkLocationDetails)[1].networkNames))[0]\r\n| extend icon = ResultSignature\r\n| project TimeGenerated, ['🚪Signin']=icon, Status=ResultSignature, RiskState, AppDisplayName, DisplayName=Identity, UserPrincipalName, UserId, UserType, Country=Location, State, City, DeviceName, OS, Browser, IPAddress, Network, NetworkType, MFA=AuthenticationRequirement, CA_Status=ConditionalAccessStatus",
