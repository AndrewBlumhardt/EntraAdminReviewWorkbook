            "name": "Signin Logs Query"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "SigninLogs\r\n| where UserPrincipalName == \"{UserPrincipalName}\"\r\n| summarize count() by bin(TimeGenerated, 1d), Status=ResultSignature",
