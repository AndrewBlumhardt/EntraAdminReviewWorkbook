        "groupType": "editable",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "SigninLogs\r\n| where ResultSignature == \"SUCCESS\"\r\n| summarize arg_max(TimeGenerated, *) by UserPrincipalName\r\n| where UserPrincipalName contains \"{Search}\"\r\n| extend State = LocationDetails.state\r\n| extend City = LocationDetails.city\r\n| extend DeviceName = DeviceDetail.displayName\r\n| extend FirstName = split(Identity, \" \").[0]\r\n| extend LastName = split(Identity, \" \").[-2]  //Update to match your naming pattern\r\n| extend UPN_Prefix = split(UserPrincipalName, \".admin\").[0] //Update to match your naming pattern\r\n| project TimeGenerated, DisplayName=Identity, UserPrincipalName, UserId, Country=Location, State, City, DeviceName, IPAddress, FirstName, LastName, UPN_Prefix",
